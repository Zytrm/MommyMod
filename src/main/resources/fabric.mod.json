{
  "schemaVersion": 1,
  "id": "mommymods",
  "version": "${version}",
  "name": "MommyMods",
  "description": "Focused fishing utilities for Hypixel SkyBlock.",
  "authors": ["Zytrm"],
  "contact": {
    "homepage": "https://github.com/Zytrm/MommyMod",
    "sources": "https://github.com/Zytrm/MommyMod",
    "issues": "https://github.com/Zytrm/MommyMod/issues"
  },
  "license": "MIT",
  "icon": "assets/mommymods/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      {
        "value": "com.github.noamm9.mommymods.MommyMods",
        "adapter": "kotlin"
      }
    ]
  },
  "mixins": [
    "mommymods.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-language-kotlin": ">=${kotlin_loader_version}",
    "fabric-api": "*",
    "minecraft": "${minecraft_version}",
    "java": ">=25",
    "noammaddons": ">=1.2.2"
  }
}
